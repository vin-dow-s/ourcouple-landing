---
// Web fallback for invite deep links (https://ourcouple.app/join/CODE).
// With the app installed, iOS/Android open it directly (AASA / assetlinks)
// and this page is never seen. Without the app: store redirect, keeping the
// code visible so the partner can enter it manually after installing.
const APP_STORE_URL =
  "https://apps.apple.com/us/app/ourcouple-your-shared-space/id6758024356";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>You're invited on OurCouple 💌</title>
    <meta name="robots" content="noindex" />
    <meta property="og:title" content="Your partner invited you on OurCouple 💌" />
    <meta
      property="og:description"
      content="A private space for just the two of you — daily rituals, love notes and your couple card."
    />
    <meta property="og:type" content="website" />
    <style>
      body {
        font-family: "DM Sans", system-ui, sans-serif;
        background: #fff7f6;
        color: #3a1f22;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        padding: 24px;
        text-align: center;
      }
      .heart { font-size: 56px; margin-bottom: 16px; }
      h1 { font-size: 26px; margin: 0 0 8px; }
      p { color: #6b3f44; line-height: 1.5; max-width: 420px; margin: 0 0 8px; }
      .code {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 6px;
        background: #fff;
        border: 2px solid #e59aa0;
        border-radius: 14px;
        padding: 12px 24px;
        margin: 16px 0 24px;
      }
      .cta {
        background: #e36f84;
        color: #fff;
        font-size: 17px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 16px;
        padding: 16px 32px;
      }
      .hint { font-size: 13px; color: #a8757b; margin-top: 16px; }
    </style>
  </head>
  <body>
    <div class="heart">💌</div>
    <h1>Your partner invited you on OurCouple</h1>
    <p>Download the app, then enter this invite code to join your shared space:</p>
    <div class="code" id="invite-code">······</div>
    <a class="cta" href={APP_STORE_URL} id="store-link">Download OurCouple</a>
    <p class="hint">Already installed? Open the app and tap "Join here" with the code above.</p>
    <script>
      // The code is the last path segment (/join/ABC123 — rewritten to this
      // page by Vercel, so we read it from the URL client-side).
      const seg = location.pathname.split("/").filter(Boolean).pop();
      if (seg && /^[A-Za-z0-9]{6}$/.test(seg) && seg.toLowerCase() !== "join") {
        document.getElementById("invite-code").textContent = seg.toUpperCase();
      } else {
        document.getElementById("invite-code")?.remove();
      }
    </script>
  </body>
</html>
