---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyAppCta from '../components/StickyAppCta.astro';
import Icon from '../components/Icon.astro';
import catalog from '../data/catalog.json';

const games = catalog.games;
const appStoreUrl = "https://apps.apple.com/app/id6758024356";
---

<Layout
  title="Free Couple Games & Quizzes — Play Together (2026)"
  description="Free games and quizzes for couples: Would You Rather, the couple quiz, Truth or Dare, 36 Questions, love language, attachment style, green flags and more. No signup."
  canonicalPath="/games"
>
  <Header />

  <main class="flex-1 pt-28 pb-4 bg-gradient-radial">
    <!-- Hero -->
    <section class="pt-8 pb-6">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-text tracking-tighter mb-4">
          Couple Games &amp; Quizzes
        </h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">
          Fun, free games and quizzes for you and your partner. Play right here — no signup needed.
        </p>
      </div>
    </section>

    <!-- Grid -->
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 py-4">
        {games.map(item => (
          <a
            href={item.href}
            class="group relative overflow-hidden rounded-2xl p-5 min-h-[156px] flex flex-col justify-between shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all"
            style={`background-image: linear-gradient(135deg, ${item.gradient[0]}, ${item.gradient[1]})`}
          >
            <div class="absolute inset-0" style="background-image: linear-gradient(to top, rgba(0,0,0,0.34), rgba(0,0,0,0) 58%)"></div>
            <div class="relative w-11 h-11 rounded-xl bg-white/20 flex items-center justify-center">
              <Icon name={item.icon} class="w-6 h-6 text-white" />
            </div>
            <div class="relative mt-4">
              <h2 class="font-semibold text-lg text-white mb-1">{item.title}</h2>
              <p class="text-white/90 text-sm leading-relaxed">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- App CTA (full-width, no card) -->
    <section class="py-24">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="tracking-tighter text-3xl md:text-4xl font-bold text-text mb-4">
          These games are just the start
        </h2>
        <p class="text-base text-text-secondary mb-8 max-w-xl mx-auto">
          In the OurCouple app, you and your partner play together — building your Compatibility Score, saving your history, and growing one private space for two.
        </p>
        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block transition-transform hover:scale-105"
          aria-label="Download OurCouple on the App Store"
          data-cta-location="games_hub"
          data-fast-goal="cta_games_hub_download"
        >
          <img src="/app-store-badge.svg" alt="Download on the App Store" class="h-16 mx-auto" />
        </a>
        <p class="text-text-secondary text-sm mt-3">Free forever — one Premium covers both of you</p>
      </div>
    </section>
  </main>

  <StickyAppCta />
  <Footer />
</Layout>
