const pageSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "OurCouple Blog",
  "url": `${siteUrl}/blog`,
  "description": "Relationship tips, date ideas, and honest app reviews for couples who want to stay connected.",
  "publisher": {
    "@type": "Organization",
    "name": "OurCouple",
    "url": siteUrl
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>OurCouple Blog — Relationship Tips, Date Ideas & App Reviews</title>
    <meta name="title" content="OurCouple Blog — Relationship Tips, Date Ideas & App Reviews" />
    <meta name="description" content="Relationship tips, date ideas, and honest app reviews for couples who want to stay connected." />
    <meta name="author" content="OurCouple" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#D4A5A9" />

    <link rel="canonical" href={`${siteUrl}/blog`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/blog`} />
    <meta property="og:title" content="OurCouple Blog — Relationship Tips, Date Ideas & App Reviews" />
    <meta property="og:description" content="Relationship tips, date ideas, and honest app reviews for couples who want to stay connected." />
    <meta property="og:image" content={`${siteUrl}/og-image3.png`} />
    <meta property="og:site_name" content="OurCouple" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="OurCouple Blog — Relationship Tips, Date Ideas & App Reviews" />
    <meta name="twitter:description" content="Relationship tips, date ideas, and honest app reviews for couples who want to stay connected." />

    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

    <Font cssVariable="--font-dm-sans" preload />

    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <script
      defer
      data-website-id="dfid_qI4dBMANAwmiNsJvVpicO"
      data-domain="ourcouple.app"
      src="https://datafa.st/js/script.js">
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-background">
    <Header />

    <main class="flex-1">
      <!-- Hero -->
      <section class="bg-gradient-radial pt-28 pb-8">
        <div class="max-w-4xl mx-auto px-6 text-center">
          <h1 class="text-4xl md:text-5xl font-bold text-text tracking-tighter mb-4">
            The OurCouple Blog
          </h1>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto">
            Relationship tips, date ideas, and honest app reviews for couples who want to stay connected.
          </p>
        </div>
      </section>

      <!-- Posts Grid -->
      <section class="py-8">
        <div class="max-w-4xl mx-auto px-6">
          <div class="grid md:grid-cols-2 gap-6">
            {posts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group block bg-card border border-border rounded-2xl p-6 hover:border-primary/40 transition-all hover:shadow-lg hover:shadow-primary/5"
              >
                <span class="inline-block px-3 py-1 bg-primary/10 text-primary-dark text-xs font-medium rounded-full mb-4">
                  {post.category}
                </span>
                <h2 class="text-xl font-bold text-text tracking-tight mb-2 group-hover:text-primary-dark transition-colors">
                  {post.title}
                </h2>
                <p class="text-text-secondary text-sm mb-4 line-clamp-2">
                  {post.description}
                </p>
                <div class="flex items-center gap-3 text-xs text-text-light">
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                  <span>·</span>
                  <span>{post.readingTime}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-24 bg-gradient-radial">
        <div class="max-w-4xl mx-auto px-6 text-center">
          <h2 class="tracking-tighter text-4xl md:text-5xl font-bold text-text mb-6">
            Try OurCouple Free
          </h2>
          <p class="text-base text-text-secondary mb-10">
            Daily messages, shared memories, notes, and events — all in one private space for you and your partner.
          </p>
          <a
            href={appStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block transition-transform hover:scale-105"
          >
            <img src="/app-store-badge.svg" alt="Download on the App Store" class="h-16 mx-auto" />
          </a>
          <p class="text-text-secondary text-sm mt-2">Free 7-day trial · Cancel anytime</p>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
