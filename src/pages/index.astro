  <!-- 3D couple card tilt -->
  <script>
    const cc3dCard = document.getElementById('cc3d-card');
    const cc3dScene = cc3dCard?.closest('.cc3d-scene');
    const cc3dFloat = cc3dScene?.querySelector('.cc3d-float');
    const cc3dGlare = cc3dCard?.querySelector('.cc3d-glare');

    if (
      cc3dCard && cc3dScene && cc3dFloat &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      const MAX_DEG = 13;

      cc3dScene.addEventListener('pointerenter', () => {
        cc3dFloat.style.animationPlayState = 'paused';
      });

      cc3dScene.addEventListener('pointermove', (e) => {
        const r = cc3dScene.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        cc3dCard.style.transform =
          'perspective(1100px) rotateX(' + (-py * MAX_DEG * 2).toFixed(2) +
          'deg) rotateY(' + (px * MAX_DEG * 2).toFixed(2) + 'deg)';
        if (cc3dGlare) {
          cc3dGlare.style.opacity = '1';
          cc3dGlare.style.background =
            'radial-gradient(circle at ' + ((px + 0.5) * 100).toFixed(1) + '% ' +
            ((py + 0.5) * 100).toFixed(1) +
            '%, rgba(255,255,255,0.55), rgba(255,255,255,0) 55%)';
        }
      });

      cc3dScene.addEventListener('pointerleave', () => {
        cc3dCard.style.transform = '';
        cc3dFloat.style.animationPlayState = 'running';
        if (cc3dGlare) cc3dGlare.style.opacity = '0';
      });
    }
  </script>

  <!-- App Store CTA tracking is now handled globally in Analytics.astro
       (delegated listener → fires website_cta_clicked with the real page +
       data-cta-location on every page, not just the homepage). -->

  <!-- Android waitlist form handling -->
  <script define:vars={{
    SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
    SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  }}>
    const androidForm = document.getElementById('android-waitlist-form');
    if (androidForm) {
      androidForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const emailInput = androidForm.querySelector('input[type="email"]');
        const submitBtn = androidForm.querySelector('button[type="submit"]');
        const email = emailInput.value.trim().toLowerCase();

        emailInput.disabled = true;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Joining...';

        try {
          const response = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
              'Prefer': 'return=minimal'
            },
            body: JSON.stringify({ email, source: 'android-waitlist' })
          });

          if (response.ok) {
            if (window.posthog) {
              window.posthog.capture('website_android_waitlist', { email });
            }
            emailInput.value = '';
            submitBtn.textContent = "You're in!";
            submitBtn.classList.remove('bg-partner', 'hover:bg-partner/90');
            submitBtn.classList.add('bg-green-500');

            setTimeout(() => {
              submitBtn.textContent = 'Notify Me';
              submitBtn.classList.remove('bg-green-500');
              submitBtn.classList.add('bg-partner', 'hover:bg-partner/90');
              emailInput.disabled = false;
              submitBtn.disabled = false;
            }, 3000);
          } else if (response.status === 409) {
            submitBtn.textContent = 'Already joined!';
            setTimeout(() => {
              submitBtn.textContent = 'Notify Me';
              emailInput.disabled = false;
              submitBtn.disabled = false;
            }, 2000);
          } else {
            throw new Error('Failed to join');
          }
        } catch (error) {
          console.error('Waitlist error:', error);
          submitBtn.textContent = 'Error, retry';
          submitBtn.classList.remove('bg-partner');
          submitBtn.classList.add('bg-red-500');

          setTimeout(() => {
            submitBtn.textContent = 'Notify Me';
            submitBtn.classList.remove('bg-red-500');
            submitBtn.classList.add('bg-partner');
            emailInput.disabled = false;
            submitBtn.disabled = false;
          }, 2000);
        }
      });
    }
  </script>
