  <style>
    /* 3D interactive couple card */
    .cc3d-scene {
      display: flex;
      justify-content: center;
    }
    .cc3d-float {
      width: 100%;
      max-width: 32rem;
      animation: cc3d-float 6s ease-in-out infinite;
    }
    .cc3d-card {
      position: relative;
      border-radius: 1.5rem;
      transition: transform 0.18s ease-out;
      transform-style: preserve-3d;
      will-change: transform;
    }
    .cc3d-img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 1.5rem;
      box-shadow: 0 25px 55px -15px rgba(140, 40, 60, 0.5);
    }
    .cc3d-glare {
      position: absolute;
      inset: 0;
      border-radius: 1.5rem;
      opacity: 0;
      transition: opacity 0.3s ease-out;
      pointer-events: none;
      mix-blend-mode: soft-light;
    }
    @keyframes cc3d-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }
    @media (prefers-reduced-motion: reduce) {
      .cc3d-float { animation: none; }
      .cc3d-card { transition: none; }
    }

    /* Hero app screenshots */
    .hero-shots {
      position: relative;
      width: 100%;
      max-width: 24rem;
      display: flex;
      justify-content: center;
    }
    .hero-shot {
      border-radius: 2rem;
      overflow: hidden;
    }
    .hero-shot--front {
      position: relative;
      z-index: 2;
      width: 15rem;
      aspect-ratio: 1 / 2;
      box-shadow: 0 30px 60px -18px rgba(140, 40, 60, 0.4);
    }
    .hero-shot--back {
      position: absolute;
      left: 0;
      top: 50%;
      z-index: 1;
      width: 12.5rem;
      aspect-ratio: 1 / 2;
      transform: translateY(-50%) rotate(-10deg);
      box-shadow: 0 24px 48px -20px rgba(140, 40, 60, 0.32);
    }
    .hero-shot-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: inherit;
      display: block;
    }
    .hero-shot-ph {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 1rem;
      border: 2px dashed rgba(199, 102, 116, 0.45);
      border-radius: inherit;
      background: #ffffff;
      color: rgba(107, 63, 68, 0.55);
      font-size: 0.8rem;
      font-weight: 600;
    }

    /* "Stay in Love" — gradient spans the whole line; "Stay in" stays solid */
    .hero-love-line {
      display: inline-block;
      letter-spacing: -5px;
      background-image: linear-gradient(to right, #BE7A7C, #FF0066);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    .hero-stayin {
      color: #1B1B1B;
      -webkit-text-fill-color: #1B1B1B;
    }
    /* heart.svg for the "o" — fixed size, independent of the headline size */
    .love-heart {
      display: inline-block;
      height: 3.2rem;
      width: auto;
      vertical-align: middle;
    }
    /* Below the layout breakpoint — smaller headline, so smaller heart + tighter spacing */
    @media (max-width: 767px) {
      .hero-love-line { letter-spacing: -2px; }
      .love-heart { height: 1.6rem; }
    }
  </style>

  <!-- 3D couple card tilt -->
  <script>
    const cc3dCard = document.getElementById('cc3d-card');
    const cc3dScene = cc3dCard?.closest('.cc3d-scene');
    const cc3dFloat = cc3dScene?.querySelector('.cc3d-float');
    const cc3dGlare = cc3dCard?.querySelector('.cc3d-glare');

    if (
      cc3dCard && cc3dScene && cc3dFloat &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      const MAX_DEG = 13;

      cc3dScene.addEventListener('pointerenter', () => {
        cc3dFloat.style.animationPlayState = 'paused';
      });

      cc3dScene.addEventListener('pointermove', (e) => {
        const r = cc3dScene.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        cc3dCard.style.transform =
          'perspective(1100px) rotateX(' + (-py * MAX_DEG * 2).toFixed(2) +
          'deg) rotateY(' + (px * MAX_DEG * 2).toFixed(2) + 'deg)';
        if (cc3dGlare) {
          cc3dGlare.style.opacity = '1';
          cc3dGlare.style.background =
            'radial-gradient(circle at ' + ((px + 0.5) * 100).toFixed(1) + '% ' +
            ((py + 0.5) * 100).toFixed(1) +
            '%, rgba(255,255,255,0.55), rgba(255,255,255,0) 55%)';
        }
      });

      cc3dScene.addEventListener('pointerleave', () => {
        cc3dCard.style.transform = '';
        cc3dFloat.style.animationPlayState = 'running';
        if (cc3dGlare) cc3dGlare.style.opacity = '0';
      });
    }
  </script>

  <!-- PostHog CTA tracking -->
  <script>
    document.querySelectorAll('a[href*="apps.apple.com"]').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.posthog) {
          window.posthog.capture('website_cta_clicked', {
            cta: 'app_store',
            page: window.location.pathname,
            section: link.closest('section')?.id || 'unknown',
          });
        }
      });
    });
  </script>

  <!-- Android waitlist form handling -->
  <script define:vars={{
    SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
    SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  }}>
    const androidForm = document.getElementById('android-waitlist-form');
    if (androidForm) {
      androidForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const emailInput = androidForm.querySelector('input[type="email"]');
        const submitBtn = androidForm.querySelector('button[type="submit"]');
        const email = emailInput.value.trim().toLowerCase();

        emailInput.disabled = true;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Joining...';

        try {
          const response = await fetch(`${SUPABASE_URL}/rest/v1/waitlist`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
              'Prefer': 'return=minimal'
            },
            body: JSON.stringify({ email, source: 'android-waitlist' })
          });

          if (response.ok) {
            if (window.posthog) {
              window.posthog.capture('website_android_waitlist', { email });
            }
            emailInput.value = '';
            submitBtn.textContent = "You're in!";
            submitBtn.classList.remove('bg-partner', 'hover:bg-partner/90');
            submitBtn.classList.add('bg-green-500');

            setTimeout(() => {
              submitBtn.textContent = 'Notify Me';
              submitBtn.classList.remove('bg-green-500');
              submitBtn.classList.add('bg-partner', 'hover:bg-partner/90');
              emailInput.disabled = false;
              submitBtn.disabled = false;
            }, 3000);
          } else if (response.status === 409) {
            submitBtn.textContent = 'Already joined!';
            setTimeout(() => {
              submitBtn.textContent = 'Notify Me';
              emailInput.disabled = false;
              submitBtn.disabled = false;
            }, 2000);
          } else {
            throw new Error('Failed to join');
          }
        } catch (error) {
          console.error('Waitlist error:', error);
          submitBtn.textContent = 'Error, retry';
          submitBtn.classList.remove('bg-partner');
          submitBtn.classList.add('bg-red-500');

          setTimeout(() => {
            submitBtn.textContent = 'Notify Me';
            submitBtn.classList.remove('bg-red-500');
            submitBtn.classList.add('bg-partner');
            emailInput.disabled = false;
            submitBtn.disabled = false;
          }, 2000);
        }
      });
    }
  </script>
