---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const appStoreUrl = "https://apps.apple.com/app/id6758024356";
---

<Layout
  title="OurCouple — The Cozy Couple App for Daily Connection (Free)"
  description="The couple app to stay close: a living couple card, daily rituals, and quizzes & games to learn more about each other. One private space for two — free and end-to-end encrypted."
  canonicalPath="/"
>
  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center bg-gradient-radial overflow-hidden pt-20" id="hero">
      <!-- Decorative elements -->
      <div class="absolute top-20 left-10 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-80 h-80 bg-partner/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-12">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-center">
          <!-- Left: pitch + CTA -->
          <div class="text-center lg:text-left">
            <h1 class="animate-fade-in mb-4 tracking-tighter">
              <span class="block text-2xl md:text-4xl font-medium text-[#A9A9A9]">Stay close,</span>
              <span class="hero-love-line text-5xl md:text-[6rem] font-bold"><span class="hero-stayin">Stay in</span> L<span class="sr-only">o</span><svg class="love-heart" viewBox="0 0 135 121" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true" focusable="false"><path d="M67.5 121C50.9625 117.37 0 88.935 0 37.8125C-3.68934e-08 29.8763 2.4764 22.1413 7.07842 15.7031C11.6804 9.26498 18.1748 4.45005 25.6415 1.94041C33.1082 -0.569228 41.1687 -0.646356 48.6813 1.71996C56.1939 4.08627 62.7776 8.77606 67.5 15.125C72.2224 8.77606 78.8061 4.08627 86.3187 1.71996C93.8313 -0.646356 101.892 -0.569228 109.359 1.94041C116.825 4.45005 123.32 9.26498 127.922 15.7031C132.524 22.1413 135 29.8763 135 37.8125C135 88.935 84.0375 117.37 67.5 121ZM67.5 105.875C90.9 98.8419 120 69.5372 120 37.8125C120 31.7954 117.629 26.0247 113.41 21.77C109.19 17.5153 103.467 15.125 97.5 15.125C87.7125 15.125 77.715 21.4246 67.5 34.0313C57.285 21.4246 47.2875 15.125 37.5 15.125C31.5326 15.125 25.8097 17.5153 21.5901 21.77C17.3705 26.0247 15 31.7954 15 37.8125C15 69.5372 44.1 98.8419 67.5 105.875Z" fill="url(#love-heart-g0)"/><path d="M67 112C51.565 108.64 4 82.32 4 35C4 27.6541 6.31131 20.4944 10.6065 14.5351C14.9017 8.57585 20.9631 4.11906 27.932 1.79609C34.9009 -0.526888 42.4241 -0.59828 49.4359 1.59203C56.4476 3.78233 62.5925 8.12329 67 14C71.4075 8.12329 77.5524 3.78233 84.5641 1.59203C91.5759 -0.59828 99.0991 -0.526888 106.068 1.79609C113.037 4.11906 119.098 8.57585 123.393 14.5351C127.689 20.4944 130 27.6541 130 35C130 82.32 82.435 108.64 67 112ZM67 98C88.84 91.49 116 64.365 116 35C116 29.4305 113.788 24.089 109.849 20.1508C105.911 16.2125 100.57 14 95 14C85.865 14 76.534 19.831 67 31.5C57.466 19.831 48.135 14 39 14C33.4305 14 28.089 16.2125 24.1508 20.1508C20.2125 24.089 18 29.4305 18 35C18 64.365 45.16 91.49 67 98Z" fill="url(#love-heart-g1)"/><path d="M67 106C53.525 103.21 12 81.355 12 42.0625C12 35.9628 14.0178 30.0177 17.7676 25.0694C21.5174 20.121 26.8091 16.4203 32.893 14.4914C38.977 12.5625 45.5449 12.5032 51.6662 14.322C57.7876 16.1407 63.1522 19.7452 67 24.625C70.8478 19.7452 76.2124 16.1407 82.3338 14.322C88.4551 12.5032 95.023 12.5625 101.107 14.4914C107.191 16.4203 112.483 20.121 116.232 25.0694C119.982 30.0177 122 35.9628 122 42.0625C122 81.355 80.475 103.21 67 106ZM67 94.375C86.0667 88.9694 109.778 66.4459 109.778 42.0625C109.778 37.4378 107.846 33.0025 104.408 29.7323C100.97 26.4622 96.3068 24.625 91.4445 24.625C83.4694 24.625 75.3233 29.4668 67 39.1563C58.6767 29.4668 50.5306 24.625 42.5556 24.625C37.6933 24.625 33.0301 26.4622 29.5919 29.7323C26.1538 33.0025 24.2222 37.4378 24.2222 42.0625C24.2222 66.4459 47.9333 88.9694 67 94.375Z" fill="url(#love-heart-g2)"/><defs><linearGradient id="love-heart-g0" x1="-24.4336" y1="60.5" x2="151.875" y2="60.5" gradientUnits="userSpaceOnUse"><stop stop-color="#F3458A"/><stop offset="1" stop-color="#FF0066"/></linearGradient><linearGradient id="love-heart-g1" x1="-18.8047" y1="56" x2="145.75" y2="56" gradientUnits="userSpaceOnUse"><stop stop-color="#F3458A"/><stop offset="1" stop-color="#FF0066"/></linearGradient><linearGradient id="love-heart-g2" x1="-7.90885" y1="59.5" x2="135.75" y2="59.5" gradientUnits="userSpaceOnUse"><stop stop-color="#F3458A"/><stop offset="1" stop-color="#FF0066"/></linearGradient></defs></svg>ve</span>
            </h1>
            <p class="animate-fade-in-delay-1 text-lg md:text-xl text-text-secondary max-w-xl mx-auto lg:mx-0 mb-6">
              Your private space for two to grow your bond, save<br class="hidden lg:inline" />
              your story &amp; learn more about each other.
            </p>

            <!-- Social proof (above CTA — primes the user) -->
            <div class="animate-fade-in-delay-1 flex items-center justify-center lg:justify-start gap-2 mb-5">
              <span class="text-[#FFC107] text-base tracking-wider" aria-hidden="true">★★★★★</span>
              <span class="text-text-secondary text-sm font-medium">By a couple, for couples</span>
            </div>

            <div class="animate-fade-in-delay-2">
              <a
                href={appStoreUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block transition-transform hover:scale-105"
                aria-label="Download OurCouple on the App Store"
                data-fast-goal="cta_hero_download"
              >
                <img
                  src="/app-store-badge.svg"
                  alt="Download on the App Store"
                  width="168"
                  height="56"
                  class="h-14 w-auto mx-auto lg:mx-0"
                />
              </a>
              <!-- Trust microcopy (below CTA — removes post-click anxiety) -->
              <p class="text-text-light text-xs mt-3 text-center lg:text-left">
                Start free  ·  No ads  ·  Encrypted
              </p>
            </div>
          </div>

          <!-- Right: app screenshots -->
          <div class="animate-fade-in-delay-video flex justify-center lg:justify-end">
            <div class="hero-shots">
              <div class="hero-shot hero-shot--left" aria-hidden="true">
                <img src="/screenshotleft.png" alt="" class="hero-shot-img" loading="eager" />
              </div>
              <div class="hero-shot hero-shot--right" aria-hidden="true">
                <img src="/screenshotright.png" alt="" class="hero-shot-img" loading="eager" />
              </div>
              <div class="hero-shot hero-shot--main">
                <img
                  src="/mainscreenshot.png"
                  alt="OurCouple home screen — couple card with days together, compatibility and engagement scores, and today's ritual"
                  class="hero-shot-img"
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Couple Card Spotlight -->
    <section id="couple-card" class="py-24 bg-background overflow-hidden" data-fast-scroll="scroll_couple_card">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Mobile-only title (appears first on mobile, hidden on md+) -->
          <div class="md:hidden">
            <span class="inline-block text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-3 py-1 rounded-full mb-5">New in 2.0</span>
            <h2 class="tracking-tighter text-4xl font-bold text-text">
              Get your couple card
            </h2>
          </div>

          <!-- Copy (title hidden on mobile, shown on md+) -->
          <div class="order-3 md:order-1">
            <span class="hidden md:inline-block text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-3 py-1 rounded-full mb-5">New in 2.0</span>
            <h2 class="hidden md:block tracking-tighter text-4xl md:text-5xl font-bold text-text mb-5">
              Get your couple card
            </h2>
            <p class="text-text-secondary text-lg mb-8">
              Create, customise and share your own couple card - it grows with your relationship.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-text">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span>Anniversary date &amp; days together, at a glance</span>
              </li>
              <li class="flex items-start gap-3 text-text">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span>Compatibility &amp; engagement scores, automatically updated</span>
              </li>
              <li class="flex items-start gap-3 text-text">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span>Your partner's love notes + your virtual pet</span>
              </li>
              <li class="flex items-start gap-3 text-text">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span>Make it yours: themes, colours, layout...</span>
              </li>
            </ul>
            <a
              href={appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center gap-2 px-6 py-3.5 bg-primary text-white rounded-xl font-semibold hover:bg-primary-dark transition-colors"
              aria-label="Create your couple card — download OurCouple on the App Store"
              data-fast-goal="cta_couple_card_download"
            >
              Create our card now
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- 3D interactive couple card -->
          <div class="cc3d-scene order-2 md:order-2">
            <div class="cc3d-float">
              <div class="cc3d-stack">
                <!-- Alt design card peeking behind, to hint at customisation -->
                <div class="cc3d-card-alt" aria-hidden="true">
                  <img
                    src="/card2.png"
                    alt=""
                    width="782"
                    height="516"
                    class="cc3d-img cc3d-img--alt"
                    loading="lazy"
                  />
                </div>
                <div class="cc3d-card" id="cc3d-card">
                  <img
                    src="/couplecard.jpg"
                    alt="The OurCouple couple card — names, days together, virtual pet and compatibility gauges"
                    width="1249"
                    height="850"
                    class="cc3d-img"
                    loading="lazy"
                  />
                  <div class="cc3d-glare" aria-hidden="true"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-24 bg-card" data-fast-scroll="scroll_features">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="tracking-tighter text-4xl md:text-5xl font-bold text-center text-text mb-4">
          The little things, kept close
        </h2>
        <p class="text-text-secondary text-center text-base mb-8 sm:mb-12 max-w-2xl mx-auto">
          Six small habits that make every day count, together.
        </p>


        <div class="grid md:grid-cols-3 gap-8">
          <!-- Feature 1: Daily Check-ins -->
          <article class="p-8 rounded-2xl bg-background border border-border hover:border-primary/30 transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-xl text-text mb-3">Show up, every day</h3>
            <p class="text-text-secondary mb-3">
              A message, a photo, or a question of the day — your tiny ritual together. Builds a streak that's actually worth keeping.
            </p>
            <span class="inline-block text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">Daily check-ins</span>
          </article>

          <!-- Feature 2: Love Notes -->
          <article class="p-8 rounded-2xl bg-background border border-border hover:border-primary/30 transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2"/>
                <path d="M12 20v2"/>
                <path d="m4.93 4.93 1.41 1.41"/>
                <path d="m17.66 17.66 1.41 1.41"/>
                <path d="M2 12h2"/>
                <path d="M20 12h2"/>
                <path d="m6.34 17.66-1.41 1.41"/>
                <path d="m19.07 4.93-1.41 1.41"/>
              </svg>
            </div>
            <h3 class="font-semibold text-xl text-text mb-3">Surprise them with love notes</h3>
            <p class="text-text-secondary mb-3">
              Drop sweet notes into a shared pool. Each day, one shows up to your partner — unexpected, theirs alone.
            </p>
            <span class="inline-block text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">Love notes</span>
          </article>

          <!-- Feature 3: Memory Album -->
          <article class="p-8 rounded-2xl bg-background border border-border hover:border-primary/30 transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                <circle cx="9" cy="9" r="2"/>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
              </svg>
            </div>
            <h3 class="font-semibold text-xl text-text mb-3">The moments of your love story</h3>
            <p class="text-text-secondary mb-3">
              Save your favorite photos and the story behind each one. Not lost in a camera roll, not buried in a chat.
            </p>
            <span class="inline-block text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">Memory album</span>
          </article>

          <!-- Feature 4: Shared Notes -->
          <article class="p-8 rounded-2xl bg-background border border-border hover:border-primary/30 transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
                <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
                <path d="M10 9H8"/>
                <path d="M16 13H8"/>
                <path d="M16 17H8"/>
              </svg>
            </div>
            <h3 class="font-semibold text-xl text-text mb-3">Build something together, even from afar</h3>
            <p class="text-text-secondary mb-3">
              Plan a trip, list movies to watch, write your thoughts. You both edit live, and only the two of you see it.
            </p>
            <span class="inline-block text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">Shared notes</span>
          </article>

          <!-- Feature 5: Events & Dates -->
          <article class="p-8 rounded-2xl bg-background border border-border hover:border-primary/30 transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 2v4"/>
                <path d="M16 2v4"/>
                <rect width="18" height="18" x="3" y="4" rx="2"/>
                <path d="M3 10h18"/>
              </svg>
            </div>
            <h3 class="font-semibold text-xl text-text mb-3">Never forget the trip you promised each other</h3>
            <p class="text-text-secondary mb-3">
              Anniversaries, dates, the concert in 4 months — kept in one place. Syncs with your Apple and Google calendars.
            </p>
            <span class="inline-block text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">Events & ideas</span>
          </article>

          <!-- Feature 6: Private & Secure -->
          <article class="p-8 rounded-2xl bg-background border border-border hover:border-primary/30 transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <h3 class="font-semibold text-xl text-text mb-3">What you write here, stays here</h3>
            <p class="text-text-secondary mb-3">
              End-to-end encrypted. No ads, no tracking, nothing shared with anyone. Just the two of you, for real.
            </p>
            <span class="inline-block text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">Private & secure</span>
          </article>
        </div>
      </div>
    </section>

    <!-- Quizzes & Games Section -->
    <section id="games" class="py-24 bg-background" data-fast-scroll="scroll_games">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <span class="inline-block text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-3 py-1 rounded-full mb-5">Quizzes &amp; games</span>
          <h2 class="tracking-tighter text-4xl md:text-5xl font-bold text-text mb-4">
            Learn more about each other
          </h2>
          <p class="text-text-secondary text-base md:text-lg">
            Couple quizzes and playful games made for two. Answer together, compare your picks, and discover how in sync you really are — every game feeds your couple card's compatibility score.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          <div class="p-6 rounded-2xl bg-card border border-border">
            <h3 class="font-semibold text-lg text-text mb-1">Couple quiz</h3>
            <p class="text-text-secondary text-sm">How well do you really know your partner?</p>
          </div>
          <div class="p-6 rounded-2xl bg-card border border-border">
            <h3 class="font-semibold text-lg text-text mb-1">Would you rather</h3>
            <p class="text-text-secondary text-sm">Playful this-or-that prompts, just for two.</p>
          </div>
          <div class="p-6 rounded-2xl bg-card border border-border">
            <h3 class="font-semibold text-lg text-text mb-1">Love language</h3>
            <p class="text-text-secondary text-sm">Decode how you each give and feel love.</p>
          </div>
          <div class="p-6 rounded-2xl bg-card border border-border">
            <h3 class="font-semibold text-lg text-text mb-1">36 questions to fall in love</h3>
            <p class="text-text-secondary text-sm">The classic set that builds closeness fast.</p>
          </div>
          <div class="p-6 rounded-2xl bg-card border border-border">
            <h3 class="font-semibold text-lg text-text mb-1">Truth or dare</h3>
            <p class="text-text-secondary text-sm">Sweet, playful or spicy — your call.</p>
          </div>
          <div class="p-6 rounded-2xl bg-card border border-border">
            <h3 class="font-semibold text-lg text-text mb-1">Attachment style</h3>
            <p class="text-text-secondary text-sm">Understand your patterns, together.</p>
          </div>
        </div>

        <div class="text-center mt-10">
          <a
            href="/tools"
            class="inline-flex items-center gap-2 text-primary hover:text-primary-dark font-semibold transition-colors"
            data-fast-goal="cta_games_try_free"
          >
            Try a few free on the web
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <p class="text-text-light text-sm mt-1">All quizzes &amp; games are in the app.</p>
        </div>
      </div>
    </section>

    <!-- Comparison Section -->
    <section id="why" class="py-24 bg-background" data-fast-scroll="scroll_comparison">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="tracking-tighter text-4xl md:text-5xl font-bold text-center text-text mb-4">
          Why couples love it
        </h2>
        <p class="text-text-secondary text-center text-base mb-12 max-w-xl mx-auto">
          OurCouple is calm and focused, not cluttered.
        </p>

        <div class="overflow-x-auto rounded-2xl border border-border bg-card">
          <table class="w-full text-sm md:text-base">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left p-4 md:p-5 font-semibold text-text-secondary"></th>
                <th class="p-4 md:p-5 font-semibold text-primary-dark bg-primary/5">OurCouple</th>
                <th class="p-4 md:p-5 font-semibold text-text-secondary">Paired</th>
                <th class="p-4 md:p-5 font-semibold text-text-secondary">Between</th>
              </tr>
            </thead>
            <tbody class="text-text">
              <tr class="border-b border-border">
                <td class="p-4 md:p-5 font-medium">Living couple card</td>
                <td class="p-4 md:p-5 text-center bg-primary/5">✓</td>
