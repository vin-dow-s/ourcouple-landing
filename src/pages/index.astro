  <style>
    /* 3D interactive couple card */
    .cc3d-scene {
      display: flex;
      justify-content: center;
      margin-top: 6rem;
    }
    .cc3d-float {
      width: 100%;
      max-width: 26rem;
      animation: cc3d-float 6s ease-in-out infinite;
    }
    .cc3d-stack {
      position: relative;
    }
    .cc3d-card {
      position: relative;
      z-index: 2;
      border-radius: 1.5rem;
      transition: transform 0.18s ease-out;
      transform-style: preserve-3d;
      will-change: transform;
    }
    .cc3d-card-alt {
      position: absolute;
      top: -35%;
      right: -8%;
      width: 75%;
      z-index: 1;
      transform: rotate(6deg);
    }
    @media (max-width: 767px) {
      .cc3d-card-alt {
        top: -38%;
        right: 4%;
      }
    }
    .cc3d-img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 1.5rem;
      box-shadow: 0 25px 55px -15px rgba(140, 40, 60, 0.5);
    }
    .cc3d-img--alt {
      box-shadow: 0 20px 40px -16px rgba(140, 40, 60, 0.35);
      opacity: 0.95;
    }
    .cc3d-glare {
      position: absolute;
      inset: 0;
      border-radius: 1.5rem;
      opacity: 0;
      transition: opacity 0.3s ease-out;
      pointer-events: none;
      mix-blend-mode: soft-light;
    }
    @keyframes cc3d-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }
    @media (prefers-reduced-motion: reduce) {
      .cc3d-float { animation: none; }
      .cc3d-card { transition: none; }
    }

    /* Hero app screenshots — 3-phone composition (main center, left & right tilted) */
    .hero-shots {
      position: relative;
      width: 100%;
      max-width: 30rem;
      display: flex;
      justify-content: center;
    }
    .hero-shot {
      border-radius: 2rem;
      overflow: hidden;
    }
    .hero-shot--main {
      position: relative;
      z-index: 3;
      width: 13rem;
      aspect-ratio: 1284 / 2778;
    }
    .hero-shot--left {
      position: absolute;
      left: 0;
      top: 50%;
      z-index: 1;
      width: 10rem;
      aspect-ratio: 1284 / 2778;
      transform: translate(15%, -50%) rotate(-5deg);
    }
    .hero-shot--right {
      position: absolute;
      right: 0;
      top: 50%;
      z-index: 2;
      width: 10rem;
