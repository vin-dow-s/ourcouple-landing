---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ShareButtons from '../../components/tools/ShareButtons.astro';
import questions from '../../data/would-you-rather.json';
---

<ToolLayout
  title="Would You Rather: Couples Edition — Free Online Game (40+ Questions)"
  description="Play Would You Rather online with your partner — 40+ fun couples questions, from silly to spicy. Compare answers in real time. Free, no signup."
  canonicalPath="/tools/would-you-rather"
  howTo={{
    name: "How to play Would You Rather with your partner",
    description: "Free online Would You Rather game for couples — answer, hand the phone over, compare.",
    steps: [
      { name: "Player 1 answers", text: "Read each Would You Rather question and tap your favorite of the two options." },
      { name: "Hand the phone — or send a link", text: "Hand your phone to your partner, or send them a link if you're long-distance." },
      { name: "Compare answers", text: "See your compatibility score and exactly where you agreed and disagreed — and laugh about it together." }
    ]
  }}
  faqs={[
    {
      question: "How do you play Would You Rather as a couple?",
      answer: "Player 1 answers all the questions on their device. When done, they either hand the phone to Player 2 — who answers the same questions — or send a link to Player 2 so they can play remotely. After both players have answered, the game shows a compatibility score and highlights exactly where you agreed and disagreed."
    },
    {
      question: "Is this game free?",
      answer: "Yes, 100% free. No signup required, no email needed, no hidden paywalls. Just open the page and start playing."
    },
    {
      question: "How many questions are there?",
      answer: "40+ questions across 4 categories: Fun, Romantic, Deep, and Spicy. You can filter by category before starting, or play all of them."
    },
    {
      question: "Can we play this long distance?",
      answer: "Yes. After Player 1 finishes, tap 'Send to your partner' to generate a shareable link. Your partner opens the link, answers the same questions, and the game compares your answers automatically."
    },
    {
      question: "Just want to read the questions without playing?",
      answer: "All questions are listed below the game by category. No login or play required — just scroll down."
    }
  ]}
>
  <div class="max-w-2xl mx-auto px-4">
    <!-- Hero -->
    <div class="text-center mb-8 animate-fade-in">
      <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-text tracking-tight mb-3">
        Would You Rather — Couples Edition
      </h1>
      <p id="hero-subtitle" class="text-text-secondary">
        40+ fun questions for couples. You answer, hand to your partner, compare results.
      </p>
    </div>

    <!-- Category Filter -->
    <div id="category-filter" class="mb-6">
      <div class="flex flex-wrap gap-2 justify-center">
        <button class="cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-primary text-white" data-category="all">All</button>
        <button class="cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-card border border-border text-text-secondary hover:border-primary/30" data-category="fun">Fun</button>
        <button class="cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-card border border-border text-text-secondary hover:border-primary/30" data-category="romantic">Romantic</button>
        <button class="cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-card border border-border text-text-secondary hover:border-primary/30" data-category="deep">Deep</button>
        <button class="cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-card border border-border text-text-secondary hover:border-primary/30" data-category="spicy">Spicy</button>
      </div>
    </div>

    <!-- Mode: Player 1 -->
    <div id="mode-together-p1">
      <div class="bg-primary/5 rounded-2xl border border-primary/20 p-4 mb-6 text-center">
        <p class="text-text font-medium">Player 1</p>
        <p class="text-text-secondary text-sm">Answer all questions, then pass the phone to your partner — or send them a link.</p>
      </div>

      <!-- Progress -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span id="p1-category-badge" class="px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary-dark capitalize"></span>
          <span class="text-sm text-text-secondary">Question <span id="p1-current-q">1</span> of <span id="p1-total-q">40</span></span>
        </div>
        <div class="h-2 bg-border rounded-full overflow-hidden">
          <div id="p1-progress-bar" class="h-full bg-primary rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <!-- Question Card -->
      <div class="bg-card rounded-2xl border border-border p-6 mb-6">
        <p class="text-text-secondary text-sm mb-2">Would you rather...</p>
        <div id="p1-options" class="space-y-3">
          <button id="p1-option-a" class="p1-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all">
            <span class="block font-medium text-text" id="p1-option-a-text"></span>
          </button>
          <div class="text-center text-text-light text-sm font-medium">OR</div>
          <button id="p1-option-b" class="p1-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all">
            <span class="block font-medium text-text" id="p1-option-b-text"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mode: Pass Phone or Send Link -->
    <div id="mode-pass-phone" class="hidden">
      <div class="bg-card rounded-2xl border border-border p-8 mb-6 text-center">
        <div class="w-16 h-16 rounded-2xl bg-partner/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-partner" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-text mb-2">Now it's your partner's turn</h2>
        <p class="text-text-secondary mb-6">
          Hand the phone to them — or send them a link if you're apart.
        </p>

        <div class="flex flex-col gap-3">
          <button
            id="hand-phone-btn"
            class="w-full px-6 py-3 bg-partner text-white rounded-xl font-semibold hover:bg-partner/90 transition-colors"
          >
            🤝 Hand to your partner
          </button>
          <button
            id="send-link-btn"
            class="w-full px-6 py-3 bg-primary-dark text-white rounded-xl font-semibold hover:bg-primary transition-colors"
          >
            📨 Send a link to your partner
          </button>
        </div>
      </div>
    </div>

    <!-- Mode: Send Link (share) -->
    <div id="mode-send-link" class="hidden">
      <div class="bg-card rounded-2xl border border-border p-6 mb-6">
        <h2 class="text-lg font-semibold text-text mb-2 text-center">Send this link to your partner</h2>
        <p class="text-text-secondary text-sm mb-5 text-center">
          They'll answer the same questions, and you'll both see the comparison once they're done.
        </p>

        <div class="flex gap-2 mb-4">
          <input
            type="text"
            id="share-link-input"
            readonly
            class="flex-1 px-4 py-3 rounded-xl border border-border bg-background text-text text-sm font-mono"
          />
          <button
            id="copy-share-link"
            class="px-4 py-3 bg-primary-dark text-white rounded-xl font-medium hover:bg-primary transition-colors whitespace-nowrap"
          >
            Copy
          </button>
        </div>

        <div class="flex flex-wrap justify-center gap-2 mb-5">
          <a
            id="share-whatsapp"
            href="#"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[#25D366] text-white hover:bg-[#20BD5A] transition-colors text-sm"
          >
            WhatsApp
          </a>
          <a
            id="share-sms"
            href="#"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[#34C759] text-white hover:bg-[#2DB84D] transition-colors text-sm"
          >
            SMS
          </a>
        </div>

        <p class="text-text-secondary text-xs text-center">
          Once your partner finishes, the comparison appears automatically when they open the link again — or when you reload this page after them.
        </p>
      </div>

      <button
        id="back-to-pass-btn"
        class="w-full px-6 py-3 border border-border rounded-xl font-medium hover:border-primary/30 transition-colors"
      >
        ← Back
      </button>
    </div>

    <!-- Mode: Player 2 -->
    <div id="mode-together-p2" class="hidden">
      <div class="bg-partner/5 rounded-2xl border border-partner/20 p-4 mb-6 text-center">
        <p class="text-text font-medium">Player 2</p>
        <p class="text-text-secondary text-sm">Now it's your turn — answer the same questions.</p>
      </div>

      <!-- Progress -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span id="p2-category-badge" class="px-3 py-1 rounded-full text-xs font-medium bg-partner/10 text-partner capitalize"></span>
          <span class="text-sm text-text-secondary">Question <span id="p2-current-q">1</span> of <span id="p2-total-q">40</span></span>
        </div>
        <div class="h-2 bg-border rounded-full overflow-hidden">
          <div id="p2-progress-bar" class="h-full bg-partner rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <!-- Question Card -->
      <div class="bg-card rounded-2xl border border-border p-6 mb-6">
        <p class="text-text-secondary text-sm mb-2">Would you rather...</p>
        <div id="p2-options" class="space-y-3">
          <button id="p2-option-a" class="p2-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all">
            <span class="block font-medium text-text" id="p2-option-a-text"></span>
          </button>
          <div class="text-center text-text-light text-sm font-medium">OR</div>
          <button id="p2-option-b" class="p2-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all">
            <span class="block font-medium text-text" id="p2-option-b-text"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mode: Results -->
    <div id="mode-results" class="hidden">
      <!-- Compatibility Score -->
      <div class="bg-primary/5 rounded-2xl border border-primary/20 p-6 mb-6 text-center">
        <p class="text-text-secondary text-sm mb-2">Compatibility Score</p>
        <div id="results-score" class="text-5xl font-bold text-primary-dark mb-2"></div>
        <p id="results-message" class="text-text-secondary"></p>
      </div>

      <!-- Disagreements -->
      <div id="results-disagreements" class="bg-card rounded-2xl border border-border p-6 mb-6 hidden">
        <h3 class="font-semibold text-text mb-4">Where you disagreed</h3>
        <div id="results-disagreement-list" class="space-y-4">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- Share -->
      <div class="text-center mb-6">
        <ShareButtons
          title="Share your results"
          text="We played Would You Rather for Couples! See how well you and your partner match:"
        />
      </div>

      <!-- Play Again -->
      <div class="text-center">
        <button id="play-again-btn" class="w-full px-6 py-3 bg-primary-dark text-white rounded-xl font-semibold hover:bg-primary transition-colors">
          Play Again
        </button>
      </div>
    </div>
  </div>

  <!-- Full Question List (static HTML for SEO + escape hatch for browsers) -->
  <div class="max-w-2xl mx-auto px-4 mt-12">
    <h2 class="text-xl font-semibold text-text mb-2">All Would You Rather Questions for Couples</h2>
    <p class="text-text-secondary text-sm mb-6">Just want to read the questions? They're all here, organized by category.</p>

    {["fun", "romantic", "deep", "spicy"].map(category => (
      <div class="mb-8">
        <h3 class="font-semibold text-text mb-3 capitalize">{category} Questions</h3>
        <ol class="space-y-3 text-text-secondary text-sm">
          {questions.filter(q => q.category === category).map(q => (
            <li class="leading-relaxed">Would you rather <strong>{q.optionA.toLowerCase()}</strong> or <strong>{q.optionB.toLowerCase()}</strong>?</li>
          ))}
        </ol>
      </div>
    ))}
  </div>

  <!-- SEO content section -->
  <div class="max-w-2xl mx-auto px-4 mt-16 prose prose-sm">
    <h2>Would You Rather for Couples — A Better Game Than 20 Questions</h2>
    <p>
      Would You Rather for couples is the simplest game two people can play to learn something new about each other. You read a question with two options, you pick yours, your partner picks theirs, and you compare. Sometimes you laugh, sometimes you raise an eyebrow, and once in a while you discover something you never knew about the person you've been with for years.
    </p>
    <p>
      This is the couples edition: 40+ Would You Rather questions written specifically for two people in a relationship. Some are silly ("Would you rather always have to whisper or always have to shout?"), some are romantic, some are surprisingly deep, and a handful lean spicy. Pick a category, or play them all.
    </p>

    <h2>How to Play Would You Rather as a Couple</h2>
    <p>
      Player 1 answers all the questions, then either hands the phone to Player 2 (same room) or sends a shareable link (long distance). Player 2 answers the same questions, and the game shows you a compatibility score plus every question where you didn't match. The disagreements are usually where the most interesting conversations start.
    </p>

    <h2>Why Would You Rather Works for Couples</h2>
    <p>
      Most relationship games are heavy: deep questions, vulnerable shares, "tell me your trauma." Would You Rather is the opposite — it's low-stakes, fun, and sneaks the deeper stuff in through humor. That's why it's our most-played couples game. It works on a first date, on a 10-year anniversary, and on a long-distance video call when you've run out of things to say.
    </p>

    <h2>Long Distance? It Still Works</h2>
    <p>
      After you finish your answers, tap "Send a link to your partner." They open the link, play through the same questions, and the comparison shows up automatically. No app, no signup, no waiting on a server.
    </p>
  </div>

  <script define:vars={{ questions }}>
    // ─── State ───────────────────────────────────────────────────────
    let mode = 'together-p1'; // together-p1, pass-phone, send-link, together-p2, results
    let currentIndex = 0;
    let filteredQuestions = [...questions];
    let activeCategory = 'all';
    let p1Answers = [];
    let p2Answers = [];
    let isTransitioning = false;
    let asyncMode = false; // true if P2 opened a shared link

    // ─── Elements ────────────────────────────────────────────────────
    const heroSubtitle = document.getElementById('hero-subtitle');
    const categoryFilter = document.getElementById('category-filter');
    const modeTogetherP1 = document.getElementById('mode-together-p1');
    const modePassPhone = document.getElementById('mode-pass-phone');
    const modeSendLink = document.getElementById('mode-send-link');
    const modeTogetherP2 = document.getElementById('mode-together-p2');
    const modeResults = document.getElementById('mode-results');

    const handPhoneBtn = document.getElementById('hand-phone-btn');
    const sendLinkBtn = document.getElementById('send-link-btn');
    const backToPassBtn = document.getElementById('back-to-pass-btn');
    const playAgainBtn = document.getElementById('play-again-btn');

    const shareLinkInput = document.getElementById('share-link-input');
    const copyShareLink = document.getElementById('copy-share-link');
    const shareWhatsapp = document.getElementById('share-whatsapp');
    const shareSms = document.getElementById('share-sms');

    const catBtns = document.querySelectorAll('.cat-btn');

    // P1 elements
    const p1CategoryBadge = document.getElementById('p1-category-badge');
    const p1CurrentQ = document.getElementById('p1-current-q');
    const p1TotalQ = document.getElementById('p1-total-q');
    const p1ProgressBar = document.getElementById('p1-progress-bar');
    const p1OptionA = document.getElementById('p1-option-a');
    const p1OptionB = document.getElementById('p1-option-b');
    const p1OptionAText = document.getElementById('p1-option-a-text');
    const p1OptionBText = document.getElementById('p1-option-b-text');

    // P2 elements
    const p2CategoryBadge = document.getElementById('p2-category-badge');
    const p2CurrentQ = document.getElementById('p2-current-q');
    const p2TotalQ = document.getElementById('p2-total-q');
    const p2ProgressBar = document.getElementById('p2-progress-bar');
    const p2OptionA = document.getElementById('p2-option-a');
    const p2OptionB = document.getElementById('p2-option-b');
    const p2OptionAText = document.getElementById('p2-option-a-text');
    const p2OptionBText = document.getElementById('p2-option-b-text');

    // Results elements
    const resultsScore = document.getElementById('results-score');
    const resultsMessage = document.getElementById('results-message');
    const resultsDisagreements = document.getElementById('results-disagreements');
    const resultsDisagreementList = document.getElementById('results-disagreement-list');

    // ─── Helpers ─────────────────────────────────────────────────────
    function hideAll() {
      modeTogetherP1.classList.add('hidden');
      modePassPhone.classList.add('hidden');
      modeSendLink.classList.add('hidden');
      modeTogetherP2.classList.add('hidden');
      modeResults.classList.add('hidden');
      categoryFilter.classList.add('hidden');
    }

    function showMode(newMode) {
      mode = newMode;
      hideAll();

      switch (newMode) {
        case 'together-p1':
          if (!asyncMode) categoryFilter.classList.remove('hidden');
          modeTogetherP1.classList.remove('hidden');
          break;
        case 'pass-phone':
          modePassPhone.classList.remove('hidden');
          break;
        case 'send-link':
          modeSendLink.classList.remove('hidden');
          break;
        case 'together-p2':
          modeTogetherP2.classList.remove('hidden');
          break;
        case 'results':
          modeResults.classList.remove('hidden');
          break;
      }
    }

    function encodeData(data) {
      return btoa(encodeURIComponent(JSON.stringify(data)));
    }

    function decodeData(encoded) {
      try {
        return JSON.parse(decodeURIComponent(atob(encoded)));
      } catch {
        return null;
      }
    }

    function filterQuestions(category) {
      if (asyncMode) return; // P2 must answer the same set as P1
      activeCategory = category;
      filteredQuestions = category === 'all' ? [...questions] : questions.filter(q => q.category === category);
      currentIndex = 0;
      p1Answers = new Array(filteredQuestions.length).fill(null);

      catBtns.forEach(btn => {
        const active = btn.dataset.category === category;
        btn.className = active
          ? 'cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-primary text-white'
          : 'cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-card border border-border text-text-secondary hover:border-primary/30';
      });

      if (mode === 'together-p1') renderP1Question();
    }

    catBtns.forEach(btn => {
      btn.addEventListener('click', () => filterQuestions(btn.dataset.category));
    });

    // ─── Player 1 ────────────────────────────────────────────────────
    function renderP1Question() {
      if (filteredQuestions.length === 0) return;
      const q = filteredQuestions[currentIndex];
      const total = filteredQuestions.length;
      const progress = (currentIndex / total) * 100;

      p1CategoryBadge.textContent = q.category;
      p1CurrentQ.textContent = currentIndex + 1;
      p1TotalQ.textContent = total;
      p1ProgressBar.style.width = `${progress}%`;

      p1OptionAText.textContent = q.optionA;
      p1OptionBText.textContent = q.optionB;

      p1OptionA.className = 'p1-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all';
      p1OptionB.className = 'p1-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all';

      if (p1Answers[currentIndex] === 'A') {
        p1OptionA.className = 'p1-option w-full p-5 rounded-xl border border-primary bg-primary/10 text-left transition-all';
      } else if (p1Answers[currentIndex] === 'B') {
        p1OptionB.className = 'p1-option w-full p-5 rounded-xl border border-primary bg-primary/10 text-left transition-all';
      }
    }

    function handleP1Choice(choice) {
      if (isTransitioning) return;
      isTransitioning = true;

      p1Answers[currentIndex] = choice;

      if (choice === 'A') {
        p1OptionA.className = 'p1-option w-full p-5 rounded-xl border border-primary bg-primary/10 text-left transition-all';
        p1OptionB.className = 'p1-option w-full p-5 rounded-xl border border-border text-left transition-all opacity-50';
      } else {
        p1OptionB.className = 'p1-option w-full p-5 rounded-xl border border-primary bg-primary/10 text-left transition-all';
        p1OptionA.className = 'p1-option w-full p-5 rounded-xl border border-border text-left transition-all opacity-50';
      }

      setTimeout(() => {
        if (currentIndex < filteredQuestions.length - 1) {
          currentIndex++;
          renderP1Question();
        } else {
          p1ProgressBar.style.width = '100%';
          showMode('pass-phone');
        }
        isTransitioning = false;
      }, 500);
    }

    p1OptionA.addEventListener('click', () => handleP1Choice('A'));
    p1OptionB.addEventListener('click', () => handleP1Choice('B'));

    // ─── Pass-phone screen ───────────────────────────────────────────
    handPhoneBtn.addEventListener('click', () => {
      currentIndex = 0;
      p2Answers = new Array(filteredQuestions.length).fill(null);
      showMode('together-p2');
      renderP2Question();
    });

    sendLinkBtn.addEventListener('click', () => {
      const payload = encodeData({
        c: activeCategory,
        a: p1Answers
      });
      const url = `${window.location.origin}/tools/would-you-rather#p1=${payload}`;

      shareLinkInput.value = url;
      const text = "I just played Would You Rather — Couples Edition. Your turn:";
      shareWhatsapp.href = `https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`;
      shareSms.href = `sms:?body=${encodeURIComponent(text + ' ' + url)}`;

      showMode('send-link');
    });

    backToPassBtn.addEventListener('click', () => showMode('pass-phone'));

    copyShareLink.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(shareLinkInput.value);
        copyShareLink.textContent = 'Copied!';
        setTimeout(() => { copyShareLink.textContent = 'Copy'; }, 2000);
      } catch (err) {
        console.error('Copy failed:', err);
      }
    });

    // ─── Player 2 ────────────────────────────────────────────────────
    function renderP2Question() {
      if (filteredQuestions.length === 0) return;
      const q = filteredQuestions[currentIndex];
      const total = filteredQuestions.length;
      const progress = (currentIndex / total) * 100;

      p2CategoryBadge.textContent = q.category;
      p2CurrentQ.textContent = currentIndex + 1;
      p2TotalQ.textContent = total;
      p2ProgressBar.style.width = `${progress}%`;

      p2OptionAText.textContent = q.optionA;
      p2OptionBText.textContent = q.optionB;

      p2OptionA.className = 'p2-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all';
      p2OptionB.className = 'p2-option w-full p-5 rounded-xl border border-border text-left hover:border-primary/30 transition-all';

      if (p2Answers[currentIndex] === 'A') {
        p2OptionA.className = 'p2-option w-full p-5 rounded-xl border border-partner bg-partner/10 text-left transition-all';
      } else if (p2Answers[currentIndex] === 'B') {
        p2OptionB.className = 'p2-option w-full p-5 rounded-xl border border-partner bg-partner/10 text-left transition-all';
      }
    }

    function handleP2Choice(choice) {
      if (isTransitioning) return;
      isTransitioning = true;

      p2Answers[currentIndex] = choice;

      if (choice === 'A') {
        p2OptionA.className = 'p2-option w-full p-5 rounded-xl border border-partner bg-partner/10 text-left transition-all';
        p2OptionB.className = 'p2-option w-full p-5 rounded-xl border border-border text-left transition-all opacity-50';
      } else {
        p2OptionB.className = 'p2-option w-full p-5 rounded-xl border border-partner bg-partner/10 text-left transition-all';
        p2OptionA.className = 'p2-option w-full p-5 rounded-xl border border-border text-left transition-all opacity-50';
      }

      setTimeout(() => {
        if (currentIndex < filteredQuestions.length - 1) {
          currentIndex++;
          renderP2Question();
        } else {
          p2ProgressBar.style.width = '100%';
          calculateResults();
        }
        isTransitioning = false;
      }, 500);
    }

    p2OptionA.addEventListener('click', () => handleP2Choice('A'));
    p2OptionB.addEventListener('click', () => handleP2Choice('B'));

    // ─── Results ─────────────────────────────────────────────────────
    function calculateResults() {
      const total = filteredQuestions.length;
      let matches = 0;
      const disagreements = [];

      for (let i = 0; i < total; i++) {
        if (p1Answers[i] === p2Answers[i]) {
          matches++;
        } else {
          const q = filteredQuestions[i];
          disagreements.push({
            question: q,
            p1Choice: p1Answers[i] === 'A' ? q.optionA : q.optionB,
            p2Choice: p2Answers[i] === 'A' ? q.optionA : q.optionB
          });
        }
      }

      const score = total > 0 ? Math.round((matches / total) * 100) : 0;
      resultsScore.textContent = `${score}%`;

      if (score >= 80) {
        resultsMessage.textContent = 'Amazing! You two are incredibly in sync.';
      } else if (score >= 60) {
        resultsMessage.textContent = 'Great match! You agree on most things, with just enough difference to keep it interesting.';
      } else if (score >= 40) {
        resultsMessage.textContent = 'A balanced mix. You share some preferences, but bring different perspectives too.';
      } else {
        resultsMessage.textContent = 'Opposites attract! You have very different preferences — lots of fun debates ahead.';
      }

      if (disagreements.length > 0) {
        resultsDisagreements.classList.remove('hidden');
        resultsDisagreementList.innerHTML = disagreements.map(d => `
          <div class="p-4 rounded-xl bg-background border border-border">
            <p class="text-sm text-text-secondary mb-3">Would you rather...</p>
            <p class="font-medium text-text text-sm mb-3">${d.question.optionA} <span class="text-text-light">vs</span> ${d.question.optionB}</p>
            <div class="grid grid-cols-2 gap-3">
              <div class="px-3 py-2 rounded-lg bg-primary/5 border border-primary/20">
                <p class="text-xs text-text-light mb-1">Player 1</p>
                <p class="text-sm font-medium text-text">${d.p1Choice}</p>
              </div>
              <div class="px-3 py-2 rounded-lg bg-partner/5 border border-partner/20">
                <p class="text-xs text-text-light mb-1">Player 2</p>
                <p class="text-sm font-medium text-text">${d.p2Choice}</p>
              </div>
            </div>
          </div>
        `).join('');
      } else {
        resultsDisagreements.classList.add('hidden');
      }

      showMode('results');
    }

    playAgainBtn.addEventListener('click', () => {
      // Reset everything, drop the hash, restart fresh
      asyncMode = false;
      currentIndex = 0;
      activeCategory = 'all';
      filteredQuestions = [...questions];
      p1Answers = new Array(filteredQuestions.length).fill(null);
      p2Answers = [];
      history.replaceState(null, '', window.location.pathname);

      catBtns.forEach(btn => {
        const active = btn.dataset.category === 'all';
        btn.className = active
          ? 'cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-primary text-white'
          : 'cat-btn px-3 py-1.5 rounded-full text-sm font-medium bg-card border border-border text-text-secondary hover:border-primary/30';
      });

      heroSubtitle.textContent = '40+ fun questions for couples. You answer, hand to your partner, compare results.';
      showMode('together-p1');
      renderP1Question();
    });

    // ─── Init: detect async P2 mode from hash ────────────────────────
    function init() {
      const hash = window.location.hash;
      if (hash.startsWith('#p1=')) {
        const decoded = decodeData(hash.substring(4));
        if (decoded && Array.isArray(decoded.a) && decoded.c) {
          // Hydrate P1 answers from link
          asyncMode = true;
          activeCategory = decoded.c;
          filteredQuestions = activeCategory === 'all' ? [...questions] : questions.filter(q => q.category === activeCategory);
          // Trim to length sent by P1 (in case categories changed)
          p1Answers = decoded.a.slice(0, filteredQuestions.length);
          p2Answers = new Array(filteredQuestions.length).fill(null);
          currentIndex = 0;

          heroSubtitle.textContent = "Your partner already played. Answer the same questions to see your compatibility.";
          showMode('together-p2');
          renderP2Question();
          return;
        }
      }

      // Default fresh game
      p1Answers = new Array(filteredQuestions.length).fill(null);
      renderP1Question();
    }

    init();
  </script>
</ToolLayout>
