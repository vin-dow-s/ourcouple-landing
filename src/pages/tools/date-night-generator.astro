---
import ToolLayout from '../../layouts/ToolLayout.astro';
import Icon from '../../components/Icon.astro';
import ShareButtons from '../../components/tools/ShareButtons.astro';
import ToolAppCta from '../../components/ToolAppCta.astro';
import dateIdeas from '../../data/bucket-list-ideas.json';

// Filter to date-night-flavored ideas (free + low budget, varied locations)
const ideas = dateIdeas.filter((idea: any) => idea.budget === 'free' || idea.budget === 'low');
---

<ToolLayout
  title="Random Date Night Generator — Free Date Ideas for Couples"
  description="Stuck in a rut? Tap to generate a random date night idea — free or cheap, at home or out. 50+ romantic, fun ideas for couples. No signup."
  canonicalPath="/tools/date-night-generator"
  howTo={{
    name: "How to use the date night generator",
    description: "Free random date night idea generator for couples.",
    steps: [
      { name: "Tap to spin", text: "Press the button to get a random date night idea instantly." },
      { name: "Read it together", text: "Show your partner. Like it? Plan it. Don't? Spin again." },
      { name: "Save your favorites", text: "Build your list of ideas you want to try together." }
    ]
  }}
  faqs={[
    {
      question: "Is the date night generator free?",
      answer: "Yes, completely free with no signup. Just tap and get a fresh idea each time."
    },
    {
      question: "Are these date ideas free?",
      answer: "Most are free or low-budget. We focus on ideas that don't require expensive reservations or fancy outfits."
    },
    {
      question: "Can we use this for at-home date nights?",
      answer: "Yes. Many ideas are designed for staying in — from cooking new cuisines to themed movie nights and writing love letters."
    },
    {
      question: "How many date ideas are there?",
      answer: "50+ ideas, refreshed regularly. From cozy nights in to small adventures within your city."
    },
    {
      question: "What if we want a longer list of ideas to plan ahead?",
      answer: "Use our Couple Bucket List tool to build a personalized shared list based on your interests, budget, and location."
    }
  ]}
>
  <div class="max-w-2xl mx-auto px-4">
    <!-- Hero -->
    <div class="text-center mb-8 animate-fade-in">
      <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
        <Icon name="moon" class="w-8 h-8 text-primary" />
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-text tracking-tight mb-3">
        Random Date Night Generator
      </h1>
      <p class="text-text-secondary max-w-md mx-auto">
        Stuck deciding what to do tonight? Tap below — get a fresh date idea for you and your partner.
      </p>
    </div>

    <!-- Generator card -->
    <div id="card" class="rounded-3xl bg-card border border-border p-6 md:p-10 mb-6 min-h-[180px] md:min-h-[260px] flex flex-col items-center justify-center text-center transition-all">
      <div id="placeholder" class="text-text-light">
        <svg class="w-12 h-12 mx-auto mb-4 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
        </svg>
        <p>Press the button to spin a date idea.</p>
      </div>
      <div id="result" class="hidden animate-fade-in">
        <h2 id="result-title" class="text-2xl md:text-3xl font-bold text-text mb-3"></h2>
        <p id="result-desc" class="text-text-secondary text-base leading-relaxed max-w-md"></p>
        <div id="result-tags" class="mt-5 flex flex-wrap gap-2 justify-center"></div>
      </div>
    </div>

    <button
      id="spin"
      type="button"
      class="w-full py-4 rounded-2xl bg-primary text-white font-medium text-base hover:bg-primary-dark active:scale-[0.99] transition-all shadow-md shadow-primary/20"
    >
      Spin a date idea ✨
    </button>
    <p class="text-text-light text-xs text-center mt-3">No signup. Spin as many times as you like.</p>

    <ToolAppCta
      kicker="Found your date?"
      heading="Plan it together in the app"
      copy="In the OurCouple app, you and your partner save date ideas, plan your nights, and keep all your memories in one private space for two."
    />

    <!-- Cross-link to bucket-list -->
    <div class="mt-12 p-5 rounded-2xl bg-primary/5 border border-primary/15 text-center">
      <p class="text-text-secondary text-sm mb-2">Want more than one idea at a time?</p>
      <a href="/tools/bucket-list" class="text-primary font-medium hover:text-primary-dark inline-flex items-center gap-1">
        Build your shared Couple Bucket List
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <ShareButtons
      title="Random Date Night Generator — OurCouple"
      url="https://ourcouple.app/tools/date-night-generator"
    />
  </div>

  <script is:inline define:vars={{ ideas }}>
    const card = document.getElementById('card');
    const placeholder = document.getElementById('placeholder');
    const result = document.getElementById('result');
    const titleEl = document.getElementById('result-title');
    const descEl = document.getElementById('result-desc');
    const tagsEl = document.getElementById('result-tags');
    const btn = document.getElementById('spin');

    let lastId = null;

    btn.addEventListener('click', () => {
      let pick;
      do {
        pick = ideas[Math.floor(Math.random() * ideas.length)];
      } while (ideas.length > 1 && pick.id === lastId);
      lastId = pick.id;

      placeholder.classList.add('hidden');
      result.classList.remove('hidden');
      titleEl.textContent = pick.title;
      descEl.textContent = pick.description;

      tagsEl.innerHTML = '';
      const tagLabels = {
        free: 'Free',
        low: 'Low budget',
        medium: 'Mid budget',
        home: 'At home',
        local: 'Out & about',
        travel: 'Travel'
      };
      const tags = [pick.budget, pick.location].filter(Boolean);
      tags.forEach(t => {
        const span = document.createElement('span');
        span.className = 'text-xs px-3 py-1 rounded-full bg-primary/10 text-primary-dark font-medium';
        span.textContent = tagLabels[t] ?? t;
        tagsEl.appendChild(span);
      });

      card.classList.add('ring-2', 'ring-primary/30');
      setTimeout(() => card.classList.remove('ring-2', 'ring-primary/30'), 400);
    });
  </script>
</ToolLayout>
