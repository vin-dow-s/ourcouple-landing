---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AnniversaryCalculatorWidget from '../../components/tools/AnniversaryCalculatorWidget.astro';
---

<ToolLayout
  title="How Long Have We Been Dating? Free Anniversary Calculator"
  description="Calculate how many days, weeks, and months you've been together. Discover milestones like 100 days, 520 days, 1000 days, and more. Free, instant."
  canonicalPath="/tools/anniversary-calculator"
  howTo={{
    name: "How to calculate how long you've been together",
    description: "Free anniversary calculator — find out exactly how long you've been dating.",
    steps: [
      { name: "Enter the date you started dating", text: "Pick the day your relationship began on the calendar." },
      { name: "See your total time together", text: "Get an instant breakdown in days, weeks, months, and years." },
      { name: "Discover upcoming milestones", text: "See every milestone coming up — 100 days, 520 days, 1 year, 1000 days, and more." }
    ]
  }}
  faqs={[
    {
      question: "How do you count months in a relationship?",
      answer: "Count each calendar month from the day you started dating. If you started on the 15th, your monthly anniversary is the 15th of each following month."
    },
    {
      question: "What is the 100-day anniversary?",
      answer: "100 days is a popular milestone in many cultures, especially in Korea and Japan. It marks 100 full days since your relationship began."
    },
    {
      question: "Why is 520 days special?",
      answer: "In Chinese culture, 520 sounds like 'I love you' (wǔ èr líng ≈ wǒ ài nǐ), so 520 days is celebrated as a romantic milestone."
    },
    {
      question: "Is the anniversary calculator free?",
      answer: "Yes, completely free with instant results. No signup, no email required."
    },
    {
      question: "Does it work for marriage anniversaries too?",
      answer: "Yes. Just use your wedding date instead of your dating date and you'll get the same milestones counted from your marriage."
    }
  ]}
>
  <div class="max-w-2xl mx-auto px-4">
    <!-- Hero -->
    <div class="text-center mb-8 animate-fade-in">
      <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-text tracking-tighter mb-3">
        Anniversary Calculator
      </h1>
      <p class="text-text-secondary">
        Enter your anniversary date to see how long you've been together and discover upcoming milestones.
      </p>
    </div>

    <AnniversaryCalculatorWidget />

    <!-- FAQ -->
    <div class="mt-12">
      <h2 class="text-xl font-semibold text-text text-center mb-6">Frequently Asked Questions</h2>
      <div class="space-y-3">
        <details class="group bg-card rounded-xl border border-border">
          <summary class="flex items-center justify-between p-4 cursor-pointer">
            <span class="font-medium text-text">How do I calculate how long we've been dating?</span>
            <svg class="w-5 h-5 text-text-secondary group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            Enter the date you became a couple (your first date, the day you became official, or any date meaningful to you) and our calculator instantly shows you the exact number of days, weeks, and months you've been together — plus all your upcoming milestones.
          </div>
        </details>

        <details class="group bg-card rounded-xl border border-border">
          <summary class="flex items-center justify-between p-4 cursor-pointer">
            <span class="font-medium text-text">What are the most important relationship milestones?</span>
            <svg class="w-5 h-5 text-text-secondary group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            Popular milestones include 100 days (a tradition in Korean dating culture), 520 days ("I love you" in Chinese culture), 1000 days, and yearly anniversaries. Our calculator tracks 22 milestones from 30 days to 50 years, so you never miss a special date.
          </div>
        </details>

        <details class="group bg-card rounded-xl border border-border">
          <summary class="flex items-center justify-between p-4 cursor-pointer">
            <span class="font-medium text-text">What date should I use for my anniversary?</span>
            <svg class="w-5 h-5 text-text-secondary group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            Use whatever date feels meaningful to you! Common choices include: the day you started dating, your first date, the day you met, or when you became "official." The best date is the one you both agree on.
          </div>
        </details>

        <details class="group bg-card rounded-xl border border-border">
          <summary class="flex items-center justify-between p-4 cursor-pointer">
            <span class="font-medium text-text">What is the 100 days anniversary?</span>
            <svg class="w-5 h-5 text-text-secondary group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            The 100 days anniversary is a popular milestone in Korean dating culture (called "baegil"). Couples celebrate reaching 100 days together with gifts and special dates. It's become popular worldwide as a way to celebrate early relationship milestones.
          </div>
        </details>
      </div>
    </div>

    <!-- FAQ Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I calculate how long we've been dating?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Enter the date you became a couple (your first date, the day you became official, or any date meaningful to you) and our calculator instantly shows you the exact number of days, weeks, and months you've been together — plus all your upcoming milestones."
          }
        },
        {
          "@type": "Question",
          "name": "What are the most important relationship milestones?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Popular milestones include 100 days (a tradition in Korean dating culture), 520 days ('I love you' in Chinese culture), 1000 days, and yearly anniversaries. Our calculator tracks 22 milestones from 30 days to 50 years, so you never miss a special date."
          }
        },
        {
          "@type": "Question",
          "name": "What date should I use for my anniversary?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use whatever date feels meaningful to you! Common choices include: the day you started dating, your first date, the day you met, or when you became 'official.' The best date is the one you both agree on."
          }
        },
        {
          "@type": "Question",
          "name": "What is the 100 days anniversary?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 100 days anniversary is a popular milestone in Korean dating culture (called 'baegil'). Couples celebrate reaching 100 days together with gifts and special dates. It's become popular worldwide as a way to celebrate early relationship milestones."
          }
        }
      ]
    }
    </script>
  </div>

</ToolLayout>
