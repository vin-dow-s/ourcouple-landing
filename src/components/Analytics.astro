---
// Shared analytics scripts: DataFast + PostHog
// Loaded lazily after the page is idle (or on first user interaction)
// to keep them off the critical path and protect Core Web Vitals.
---

<script>
  // @ts-nocheck
  let loaded = false;

  const loadDataFast = () => {
    const s = document.createElement('script');
    s.defer = true;
    s.dataset.websiteId = 'dfid_qI4dBMANAwmiNsJvVpicO';
    s.dataset.domain = 'ourcouple.app';
    s.src = 'https://datafa.st/js/script.js';
    document.head.appendChild(s);
  };

  const loadPostHog = async () => {
    const { default: posthog } = await import('posthog-js');
    posthog.init('phc_2ZAsUSvL9xkYDQjpB430ApXZ0HLkW7rbRf5PLFdBYGp', {
      api_host: 'https://eu.i.posthog.com',
      person_profiles: 'identified_only',
      capture_pageview: true,
    });
    window.posthog = posthog;
  };

  const loadAll = () => {
    if (loaded) return;
    loaded = true;
    loadDataFast();
    loadPostHog();
  };

  const events = ['pointerdown', 'keydown', 'scroll', 'touchstart'];
  const onInteract = () => {
    events.forEach((e) => window.removeEventListener(e, onInteract));
    loadAll();
  };
  events.forEach((e) => window.addEventListener(e, onInteract, { once: true, passive: true }));

  if ('requestIdleCallback' in window) {
    requestIdleCallback(loadAll, { timeout: 4000 });
  } else {
    setTimeout(loadAll, 3000);
  }

  // Track every App Store CTA click site-wide (delegated → fires on EVERY page,
  // not just the homepage). Records the real pathname + which CTA fired, so
  // blog/tool CTAs are no longer invisible in PostHog. Replaces the old
  // homepage-only listener that made `page` always "/".
  document.addEventListener('click', (e) => {
    const link = e.target.closest && e.target.closest('a[href*="apps.apple.com"]');
    if (!link) return;
    loadAll(); // make sure analytics start loading even on first interaction
    if (window.posthog) {
      window.posthog.capture('website_cta_clicked', {
        cta: 'app_store',
        page: window.location.pathname,
        location: link.dataset.ctaLocation || 'unknown',
      });
    }
  }, { capture: true });
</script>
