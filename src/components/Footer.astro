---
const appStoreUrl = "https://apps.apple.com/app/id6758024356";
---

<footer class="bg-card border-t border-border py-12">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-start justify-between gap-8 mb-8">
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-3">
          <picture>
            <source srcset="/logo-192.webp" type="image/webp" />
            <img src="/logo-96.png" alt="OurCouple" width="48" height="48" class="w-12 h-12 rounded-xl" loading="lazy" decoding="async" />
          </picture>
          <div class="flex flex-col">
            <span class="font-semibold text-xl text-text tracking-tighter">OurCouple</span>
            <span class="text-text-secondary text-sm italic">Stay close, stay in love</span>

          </div>
        </div>
        <p class="text-text-secondary text-sm max-w-xs mt-4">One shared space for you and your partner to save everything and learn more about each other.</p>
        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-block transition-transform hover:scale-105 w-fit"
          aria-label="Download OurCouple on the App Store"
        >
          <img
            src="/app-store-badge.svg"
            alt="Download on the App Store"
            width="144"
            height="48"
            class="h-12 w-auto"
            loading="lazy"
          />
        </a>
      </div>

      <div class="flex flex-col max-sm:mt-12 sm:flex-row sm:flex-wrap gap-8 sm:gap-12">
        <!-- Sections Column -->
        <div class="flex flex-col gap-3">
          <h3 class="font-semibold text-text text-sm mb-1">Sections</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/" class="text-text-secondary hover:text-primary transition-colors">Home</a>
            <a href="/#features" class="text-text-secondary hover:text-primary transition-colors">Features</a>
            <a href="/#faq" class="text-text-secondary hover:text-primary transition-colors">FAQ</a>
            <a href="mailto:vincent@ourcouple.app" class="text-text-secondary hover:text-primary transition-colors">Contact</a>
          </nav>
        </div>

        <!-- Blog Column -->
        <div class="flex flex-col gap-3">
          <h3 class="font-semibold text-text text-sm mb-1">Blog</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/blog" class="text-text-secondary hover:text-primary transition-colors">All Posts</a>
            <a href="/blog/how-well-do-you-know-your-partner" class="text-text-secondary hover:text-primary transition-colors">Know Your Partner</a>
            <a href="/blog/how-long-have-we-been-dating" class="text-text-secondary hover:text-primary transition-colors">How Long Dating</a>
            <a href="/blog/best-couples-journal-apps" class="text-text-secondary hover:text-primary transition-colors">Best Couples Apps</a>
            <a href="/blog/questions-to-ask-your-partner" class="text-text-secondary hover:text-primary transition-colors">Questions for Couples</a>
            <a href="/blog/free-date-night-ideas" class="text-text-secondary hover:text-primary transition-colors">Date Night Ideas</a>
          </nav>
        </div>

        <!-- OurCouple For Column -->
        <div class="flex flex-col gap-3">
          <h3 class="font-semibold text-text text-sm mb-1">OurCouple For</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/for/long-distance-couples" class="text-text-secondary hover:text-primary transition-colors">Long-Distance Couples</a>
            <a href="/for/new-couples" class="text-text-secondary hover:text-primary transition-colors">New Couples</a>
            <a href="/for/busy-couples" class="text-text-secondary hover:text-primary transition-colors">Busy Couples</a>
            <a href="/for/married-couples" class="text-text-secondary hover:text-primary transition-colors">Married Couples</a>
          </nav>
        </div>

        <!-- Games Column -->
        <div class="flex flex-col gap-3">
          <h3 class="font-semibold text-text text-sm mb-1">Games &amp; Quizzes</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/tools/would-you-rather" class="text-text-secondary hover:text-primary transition-colors">Would You Rather</a>
            <a href="/tools/couple-quiz" class="text-text-secondary hover:text-primary transition-colors">Couple Quiz</a>
            <a href="/tools/truth-or-dare-couples" class="text-text-secondary hover:text-primary transition-colors">Truth or Dare</a>
            <a href="/tools/love-language" class="text-text-secondary hover:text-primary transition-colors">Love Language Quiz</a>
            <a href="/tools/attachment-style" class="text-text-secondary hover:text-primary transition-colors">Attachment Style</a>
            <a href="/games" class="text-primary hover:text-primary-dark font-medium transition-colors">See all games →</a>
          </nav>
        </div>

        <!-- Tools Column -->
        <div class="flex flex-col gap-3">
          <h3 class="font-semibold text-text text-sm mb-1">Tools</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/tools/anniversary-calculator" class="text-text-secondary hover:text-primary transition-colors">Anniversary Calculator</a>
            <a href="/tools/monthsary-counter" class="text-text-secondary hover:text-primary transition-colors">Monthsary Counter</a>
            <a href="/tools/date-night-generator" class="text-text-secondary hover:text-primary transition-colors">Date Night Generator</a>
            <a href="/tools/bucket-list" class="text-text-secondary hover:text-primary transition-colors">Bucket List</a>
            <a href="/tools" class="text-primary hover:text-primary-dark font-medium transition-colors">See all tools →</a>
          </nav>
        </div>

        <!-- Legal Column -->
        <div class="flex flex-col gap-3">
          <h3 class="font-semibold text-text text-sm mb-1">Legal</h3>
          <nav class="flex flex-col gap-2 text-sm">
            <a href="/privacy" class="text-text-secondary hover:text-primary transition-colors">Privacy</a>
            <a href="/terms" class="text-text-secondary hover:text-primary transition-colors">Terms</a>
            <a href="/delete-account" class="text-text-secondary hover:text-primary transition-colors">Delete Account</a>
          </nav>
        </div>
      </div>
    </div>

    <p class="text-text-light text-sm text-center pt-6 border-t border-border">
      &copy; 2026 OurCouple. Made with love
    </p>

    <!-- Launch / directory badges. All normalized to a 32px row height. -->
    <div class="flex flex-wrap items-center justify-center gap-2.5 mt-5">
      <a
        href="https://startupfa.me/s/ourcouple?utm_source=ourcouple.app"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src="https://startupfa.me/badges/featured-badge-small.webp"
          alt="OurCouple — Featured on Startup Fame"
          width="224"
          height="36"
          class="h-8 w-auto"
          loading="lazy"
          decoding="async"
        />
      </a>

      <a
        href="https://findyoursaas.com/tool/ourcouple-the-cozy-couple-app-for-daily-connection-free"
        target="_blank"
        rel="noopener noreferrer"
        class="fys-badge"
      >
        <img
          src="https://findyoursaas.com/fys-logo.png"
          alt=""
          width="18"
          height="18"
          loading="lazy"
          decoding="async"
        />
        <span>Featured on FYS</span>
      </a>

      <a href="https://fazier.com/launches/ourcouple.app" target="_blank" rel="noopener noreferrer">
        <img
          src="https://fazier.com/api/v1//public/badges/launch_badges.svg?badge_type=launched&theme=neutral"
          alt="OurCouple — Launched on Fazier"
          width="120"
          height="32"
          class="h-8 w-auto"
          loading="lazy"
          decoding="async"
        />
      </a>

      <a
        href="https://www.tinystartups.com/startup/ourcouple"
        target="_blank"
        rel="noopener noreferrer"
        class="ts-badge"
        aria-label="OurCouple — Launched on Tiny Startups"
      >
        <svg viewBox="0 0 100 100" aria-hidden="true">
          <defs>
            <linearGradient id="ts-grad" x1=".1" y1="0" x2=".9" y2="1">
              <stop offset="0%" stop-color="#3525E6" />
              <stop offset="55%" stop-color="#D81FE0" />
              <stop offset="100%" stop-color="#22B8F0" />
            </linearGradient>
          </defs>
          <path d="M50 6C52 32 68 48 94 50C68 52 52 68 50 94C48 68 32 52 6 50C32 48 48 32 50 6Z" fill="url(#ts-grad)" />
        </svg>
        <span class="ts-text">
          <span class="ts-kicker">Launched on</span>
          <span class="ts-title">Tiny Startups</span>
        </span>
      </a>
    </div>
  </div>
</footer>

<style>
  /* FYS + Tiny Startups ship as raw inline-styled HTML; rebuilt here as scoped
     CSS and scaled to the same 32px height as the image badges. */
  .fys-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 32px;
    padding: 0 10px;
    border-radius: 6px;
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    box-shadow: 0 2px 4px -1px rgb(0 0 0 / 0.05);
    color: #1f2937;
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .fys-badge:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 10px -2px rgb(0 0 0 / 0.05), 0 3px 6px -2px rgb(0 0 0 / 0.05);
  }
  .fys-badge img {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: block;
  }

  .ts-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    height: 32px;
    padding: 0 10px 0 8px;
    border-radius: 8px;
    text-decoration: none;
    color: #0e0b1f;
    line-height: 1;
    background:
      linear-gradient(#fff, #fff) padding-box,
      linear-gradient(90deg, #3525e6, #d81fe0, #22b8f0) border-box;
    border: 1.5px solid transparent;
    transition: transform 0.2s ease;
  }
  .ts-badge:hover {
    transform: translateY(-1px);
  }
  .ts-badge svg {
    width: 20px;
    height: 20px;
    display: block;
    flex-shrink: 0;
  }
  .ts-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .ts-kicker {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 7px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6a6585;
  }
  .ts-title {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
</style>
