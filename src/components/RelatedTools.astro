---
import catalog from '../data/catalog.json';
import Icon from './Icon.astro';

interface Props {
  /** Current page path to exclude from the lists (e.g. "/tools/36-questions") */
  exclude?: string;
}
const { exclude } = Astro.props;

// Rotate the catalog by a per-page seed so every page surfaces a DIFFERENT set
// of 6 games/tools. Without this, slice(0,6) always showed the first 6 games and
// the newer games (this-or-that, never-have-i-ever, conflict-style, long-distance-
// bond, astro-vibes) never got any internal links.
function seedFrom(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}
function rotate<T>(arr: T[], n: number): T[] {
  if (arr.length === 0) return arr;
  const k = n % arr.length;
  return [...arr.slice(k), ...arr.slice(0, k)];
}
const seed = seedFrom(exclude ?? 'ourcouple');

const games = rotate(catalog.games.filter(t => t.href !== exclude), seed);
const tools = rotate(catalog.tools.filter(t => t.href !== exclude), seed);

const groups = [
  { label: "More games & quizzes", items: games.slice(0, 6), seeAll: "/games", seeAllLabel: "See all games" },
  { label: "More tools", items: tools.slice(0, 6), seeAll: "/tools", seeAllLabel: "See all tools" },
];
---

<section class="mt-20 md:mt-28 pt-12 border-t border-border">
  <div class="max-w-4xl mx-auto px-6 space-y-10">
    {groups.map(group => group.items.length > 0 && (
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-text">{group.label}</h2>
          <a
            href={group.seeAll}
            class="text-sm font-medium text-primary hover:text-primary-dark transition-colors whitespace-nowrap"
          >
            {group.seeAllLabel} →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {group.items.map(item => (
            <a
              href={item.href}
              class="group relative overflow-hidden rounded-2xl p-5 min-h-[140px] flex flex-col justify-between shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all"
              style={`background-image: linear-gradient(135deg, ${item.gradient[0]}, ${item.gradient[1]})`}
            >
              <div class="absolute inset-0" style="background-image: linear-gradient(to top, rgba(0,0,0,0.34), rgba(0,0,0,0) 58%)"></div>
              <div class="relative w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center">
                <Icon name={item.icon} class="w-5 h-5 text-white" />
              </div>
              <div class="relative mt-3">
                <h3 class="font-semibold text-white text-sm mb-0.5">{item.title}</h3>
                <p class="text-white/90 text-xs leading-relaxed">{item.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
