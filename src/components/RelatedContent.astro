---
interface Props {
  /** Current blog post path to exclude */
  exclude?: string;
}

const { exclude } = Astro.props;

const blogPosts = [
  {
    title: "Best Shared Notes App for Couples",
    description: "Real-time sync, shared lists, private notes — tested.",
    href: "/blog/best-shared-notes-app-for-couples",
    category: "App Guides"
  },
  {
    title: "Best Couples Apps in 2026",
    description: "Free, iPhone picks, and honest reviews.",
    href: "/blog/best-couples-apps-2026",
    category: "App Guides"
  },
  {
    title: "Relationship Rules Explained",
    description: "5-5-5, 7-7-7, 2-2-2, 3-3-3 — what they actually mean.",
    href: "/blog/relationship-rules-explained",
    category: "Connection"
  },
  {
    title: "How to Count Months in a Relationship",
    description: "The simple way couples count months and anniversaries.",
    href: "/blog/how-to-count-months-in-a-relationship",
    category: "Connection"
  },
  {
    title: "OurCouple vs Paired",
    description: "Side-by-side comparison of features, pricing, and privacy.",
    href: "/blog/ourcouple-vs-paired",
    category: "App Guides"
  },
  {
    title: "50 Free Date Night Ideas at Home",
    description: "Creative, budget-friendly date night ideas that bring you closer.",
    href: "/blog/free-date-night-ideas",
    category: "Date Ideas"
  },
  {
    title: "How Long Have We Been Dating?",
    description: "Calculate your relationship length and discover every milestone worth celebrating.",
    href: "/blog/how-long-have-we-been-dating",
    category: "Connection"
  },
  {
    title: "Questions to Ask Your Partner",
    description: "Meaningful questions to deepen your connection and understanding.",
    href: "/blog/questions-to-ask-your-partner",
    category: "Connection"
  },
  {
    title: "How Well Do You Know Your Partner?",
    description: "Put your knowledge to the test and find out how well you really know each other.",
    href: "/blog/how-well-do-you-know-your-partner",
    category: "Connection"
  },
  {
    title: "Best Couples Journal Apps",
    description: "A comparison of the best apps for shared journaling and couple memories.",
    href: "/blog/best-couples-journal-apps",
    category: "Apps"
  },
  {
    title: "Relationship Data Encryption",
    description: "How OurCouple keeps your relationship data private and secure.",
    href: "/blog/relationship-data-encryption",
    category: "Privacy"
  }
];

const allTools = [
  {
    title: "Anniversary Calculator",
    description: "Find out how many days you've been together.",
    href: "/tools/anniversary-calculator",
    emoji: "📅"
  },
  {
    title: "Monthsary Counter",
    description: "See your next monthsary date and a live countdown.",
    href: "/tools/monthsary-counter",
    emoji: "🗓️"
  },
  {
    title: "36 Questions to Fall in Love",
    description: "The famous questions that bring couples closer.",
    href: "/tools/36-questions",
    emoji: "❤️"
  },
  {
    title: "Love Language Quiz",
    description: "Discover your love language in 2 minutes.",
    href: "/tools/love-language",
    emoji: "💬"
  },
  {
    title: "Would You Rather — Couples Edition",
    description: "40+ fun questions to play with your partner.",
    href: "/tools/would-you-rather",
    emoji: "🎲"
  },
  {
    title: "How Well Do You Know Your Partner Quiz",
    description: "12 questions to compare with your partner.",
    href: "/tools/couple-quiz",
    emoji: "🧠"
  },
  {
    title: "Couple Bucket List",
    description: "Build your shared list of dreams and dates.",
    href: "/tools/bucket-list",
    emoji: "✨"
  },
  {
    title: "Date Night Generator",
    description: "Tap and get a random free date idea for tonight.",
    href: "/tools/date-night-generator",
    emoji: "🎯"
  }
];

// Pick tools that contextually match the current article
const toolPriorityByPath: Record<string, string[]> = {
  '/blog/how-long-have-we-been-dating': ['/tools/anniversary-calculator', '/tools/monthsary-counter', '/tools/couple-quiz'],
  '/blog/how-well-do-you-know-your-partner': ['/tools/couple-quiz', '/tools/would-you-rather', '/tools/36-questions'],
  '/blog/questions-to-ask-your-partner': ['/tools/36-questions', '/tools/couple-quiz', '/tools/would-you-rather'],
  '/blog/free-date-night-ideas': ['/tools/date-night-generator', '/tools/bucket-list', '/tools/would-you-rather'],
  '/blog/best-couples-journal-apps': ['/tools/anniversary-calculator', '/tools/couple-quiz', '/tools/love-language'],
  '/blog/relationship-data-encryption': ['/tools/love-language', '/tools/anniversary-calculator', '/tools/36-questions'],
  '/blog/ourcouple-vs-paired': ['/tools/couple-quiz', '/tools/anniversary-calculator', '/tools/36-questions'],
  '/blog/best-couples-apps-2026': ['/tools/anniversary-calculator', '/tools/couple-quiz', '/tools/date-night-generator'],
  '/blog/relationship-rules-explained': ['/tools/36-questions', '/tools/couple-quiz', '/tools/date-night-generator'],
  '/blog/how-to-count-months-in-a-relationship': ['/tools/monthsary-counter', '/tools/anniversary-calculator', '/tools/couple-quiz'],
  '/blog/best-shared-notes-app-for-couples': ['/tools/bucket-list', '/tools/anniversary-calculator', '/tools/couple-quiz']
};

const priorityHrefs = (exclude && toolPriorityByPath[exclude]) ?? [];
const sortedTools = [
  ...priorityHrefs.map(href => allTools.find(t => t.href === href)).filter((t): t is typeof allTools[number] => Boolean(t)),
  ...allTools.filter(t => !priorityHrefs.includes(t.href))
];
const relatedTools = sortedTools.slice(0, 3);

const posts = blogPosts.filter(p => p.href !== exclude).slice(0, 3);
---

<section class="py-12 border-t border-border">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Related articles -->
    <h2 class="text-xl font-semibold text-text mb-6">Related Articles</h2>
    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      {posts.map(post => (
        <a href={post.href} class="group p-4 rounded-xl bg-card border border-border hover:border-primary/30 transition-colors">
          <span class="text-xs font-medium text-primary">{post.category}</span>
          <h3 class="font-medium text-text group-hover:text-primary transition-colors text-sm mt-1 mb-1">{post.title}</h3>
          <p class="text-text-secondary text-xs leading-relaxed">{post.description}</p>
        </a>
      ))}
    </div>

    <!-- Related tools -->
    <h2 class="text-xl font-semibold text-text mb-6">Free Tools for Couples</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      {relatedTools.map(tool => (
        <a href={tool.href} class="group p-4 rounded-xl bg-card border border-border hover:border-primary/30 transition-colors">
          <span class="text-2xl mb-2 block">{tool.emoji}</span>
          <h3 class="font-medium text-text group-hover:text-primary transition-colors text-sm mb-1">{tool.title}</h3>
          <p class="text-text-secondary text-xs leading-relaxed">{tool.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
